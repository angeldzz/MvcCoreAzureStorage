@model List<BlobModel>

<h1 class="mb-3">Listado de Blobs</h1>

<a class="btn btn-outline-secondary btn-sm mb-3"
   asp-controller="AzureBlobs"
   asp-action="Index">
    Back to containers
</a>

@if (Model != null && Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Url</th>
                    <th>Container</th>
                    <th>Imagen</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var blob in Model)
                {
                    <tr>
                        <td>@blob.Nombre</td>
                        <td><a href="@blob.Url" target="_blank">@blob.Url</a></td>
                        <td>@blob.Container</td>
                        <td><img src="@blob.Url" alt="@blob.Nombre" width="100" class="img-thumbnail" /></td>
                        <td>
                            <a class="btn btn-warning btn-sm"
                               asp-controller="AzureBlobs"
                               asp-action="DeleteBlob"
                               asp-route-containername="@blob.Container"
                               asp-route-blobname="@blob.Nombre">
                                Delete blob
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-secondary">No blobs found in this container.</div>
}