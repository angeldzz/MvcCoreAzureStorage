@model List<string>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Azure Containers</h1>
    <a class="btn btn-primary"
       asp-controller="AzureBlobs"
       asp-action="CreateContainer">Create Container</a>
</div>

@if (Model != null && Model.Count > 0)
{
    <ul class="list-group">
        @foreach (string container in Model)
        {
            <li class="list-group-item d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                <span class="fw-semibold">@container</span>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-sm btn-warning"
                       asp-controller="AzureBlobs"
                       asp-action="UploadBlob"
                       asp-route-containerName="@container">
                        Upload
                    </a>
                    <a class="btn btn-sm btn-danger"
                       asp-controller="AzureBlobs"
                       asp-action="DeleteContainer"
                       asp-route-containerName="@container">
                        Delete
                    </a>
                    <a class="btn btn-sm btn-info text-white"
                       asp-controller="AzureBlobs"
                       asp-action="ListBlobs"
                       asp-route-containerName="@container">
                        List blobs
                    </a>
                </div>
            </li>
        }
    </ul>
}
else
{
    <div class="alert alert-secondary">No containers found.</div>
}