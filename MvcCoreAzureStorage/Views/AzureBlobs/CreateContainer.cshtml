<h1 class="mb-3">Create Container</h1>

<a class="btn btn-outline-secondary btn-sm mb-3"
   asp-controller="AzureBlobs"
   asp-action="Index">
    Back to containers
</a>

<form method="post" class="card p-3 shadow-sm">
    <div class="mb-3">
        <label for="containerName" class="form-label">Container Name</label>
        <input type="text" class="form-control" id="containerName" name="containerName" required>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>